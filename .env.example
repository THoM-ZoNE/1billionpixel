# ── Solana ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
NEXT_PUBLIC_TOKEN_MINT=YOUR_TOKEN_MINT_ADDRESS
NEXT_PUBLIC_NETWORK=mainnet-beta

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/onebillionpixel

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Storage (Cloudflare R2) ──────────────────────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=1billionpixel-assets
R2_PUBLIC_URL=https://assets.1billionpixel.fun

# ── API ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
API_SECRET=your_super_secret_key

# ── Helius Webhook ───────────────────────────────────────────────────
HELIUS_API_KEY=your_helius_key
HELIUS_WEBHOOK_SECRET=your_webhook_secret
